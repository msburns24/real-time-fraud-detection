# Copy to .env. Values below are for containers on the compose network.
# If you run a component directly on your HOST, use the *host* values in the comments.

KAFKA_BOOTSTRAP_SERVERS=kafka:9092     # host: localhost:29092
KAFKA_TOPIC=transactions

REDIS_HOST=redis                       # host: localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Rolling-window size for streaming features (seconds).
# 86400 = 24h for realistic values; the grading fixture overrides this with a small window.
FEATURE_WINDOW_SECONDS=86400
# How long computed features live in Redis (seconds).
FEATURE_TTL_SECONDS=172800

MODEL_PATH=models/fraud_model_v1.pkl
API_PORT=8000
